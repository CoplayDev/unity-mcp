# Enhanced Test Dockerfile - More realistic mock Unity server
FROM python:3.11-slim as enhanced-test-base

# Set Python environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user for security
RUN groupadd -r unity --gid=1000 \
    && useradd -r -g unity --uid=1000 --home-dir=/home/unity --shell=/bin/bash unity \
    && mkdir -p /home/unity \
    && chown -R unity:unity /home/unity

# Install uv for fast Python package management
RUN pip install --no-cache-dir uv

# Install Python dependencies
WORKDIR /app/server
COPY UnityMcpBridge/UnityMcpServer~/src/pyproject.toml .
RUN uv pip install --system httpx>=0.27.2 "mcp[cli]>=1.4.1"

# Copy Unity MCP source code
COPY --chown=unity:unity UnityMcpBridge/UnityMcpServer~/src/ /app/server/
COPY --chown=unity:unity UnityMcpBridge/ /app/unity-mcp-bridge/

# Create necessary directories with proper permissions
RUN mkdir -p \
    /app/unity-projects \
    /app/builds \
    /tmp/unity-logs \
    /home/unity/.config/unity3d \
    && chown -R unity:unity /app /tmp/unity-logs /home/unity

# Copy Docker scripts
COPY docker/scripts/healthcheck.sh /app/healthcheck.sh
COPY docker/scripts/mock_headless_server.py /app/mock_headless_server.py
COPY docker/scripts/entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/healthcheck.sh /app/mock_headless_server.py /app/entrypoint.sh

# Set environment variables for enhanced mock operation
ENV UNITY_HEADLESS=true \
    UNITY_MCP_AUTOSTART=true \
    UNITY_MCP_PORT=6400 \
    UNITY_MCP_LOG_PATH=/tmp/unity-logs/unity-mcp.log \
    LOG_LEVEL=INFO \
    HOME=/home/unity \
    MOCK_UNITY_MODE=enhanced

# Expose ports
EXPOSE 8080 6400

# Health check using the enhanced mock server
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD /app/healthcheck.sh

# Switch to non-root user
USER unity

# Set working directory
WORKDIR /app

# Use the enhanced mock server that provides realistic responses
CMD ["python3", "mock_headless_server.py", "--host", "0.0.0.0", "--port", "8080", "--unity-port", "6400", "--log-level", "INFO"]

# Build metadata
LABEL maintainer="Unity MCP Team" \
      version="2.0.0-enhanced-test" \
      description="Unity MCP Enhanced Test Image - Realistic Mock Unity Server"